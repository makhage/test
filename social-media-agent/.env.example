# Anthropic (Claude) - Required for content generation
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (DALL-E) - Required for AI background generation
OPENAI_API_KEY=sk-...

# Twitter/X API - Required for Twitter publishing
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# Instagram Graph API - Required for Instagram publishing
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# TikTok Content Posting API - Required for TikTok publishing
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# Influencer profile path (default: profiles/default.yaml)
PROFILE_PATH=profiles/default.yaml

# Database path (default: data/social_agent.db)
DATABASE_URL=sqlite:///data/social_agent.db
